	name = Erdi Kilic
	email = erdican266@gmail.com

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	autoStash = true

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[alias]
	s = status -sb
	l = log --oneline -20
	lg = log --oneline --graph --all -20
	d = diff
	ds = diff --staged
	co = checkout
	cb = checkout -b
	cm = commit -m
	ca = commit --amend
	undo = reset --soft HEAD~1
	wip = !git add -A && git commit -m 'wip'
	branches = branch -a --sort=-committerdate
	recent = log --oneline -10 --no-merges

[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
